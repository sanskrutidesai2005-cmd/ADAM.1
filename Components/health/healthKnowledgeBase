// Function to match symptoms to conditions
export function matchSymptoms(selectedSymptoms) {
  const matches = [];

  Object.keys(HEALTH_CONDITIONS).forEach(conditionKey => {
    const condition = HEALTH_CONDITIONS[conditionKey];
    
    // Calculate match score
    let matchCount = 0;
    selectedSymptoms.forEach(symptom => {
      if (condition.symptoms.some(cs => 
        cs.toLowerCase().includes(symptom.toLowerCase()) || 
        symptom.toLowerCase().includes(cs.toLowerCase())
      )) {
        matchCount++;
      }
    });

    if (matchCount > 0) {
      const matchPercentage = Math.round((matchCount / condition.symptoms.length) * 100);
      matches.push({
        condition: conditionKey,
        name: condition.name,
        match_percentage: matchPercentage,
        matched_symptoms: matchCount,
        severity: condition.severity,
        explanation: condition.explanation,
        medicines: condition.medicines,
        precautions: condition.precautions
      });
    }
  });

  // Sort by match percentage and return top 3
  return matches
    .sort((a, b) => b.match_percentage - a.match_percentage)
    .slice(0, 3);
}

// Function to get age-appropriate medicine
export function getMedicineByAge(medicines, age) {
  if (age < 12) return medicines.child;
  if (age >= 60) return medicines.elderly;
  return medicines.adult;
}